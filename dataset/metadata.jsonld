  "keywords": ["dementia", "remote monitoring", "in-home sensing", "wearables", "longitudinal"],
  "isBasedOn": "https://doi.org/10.5281/zenodo.7622128",
  "publisher": {"@type": "Organization", "name": "UK Dementia Research Institute"},
  "distribution": [
